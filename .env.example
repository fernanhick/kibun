# kibun — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.

# ─── Supabase (client-safe — use EXPO_PUBLIC_ prefix) ───────────────────────
# These are safe to bundle with the client app (anon key has RLS enforced).
EXPO_PUBLIC_SUPABASE_URL=your-supabase-project-url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Server-side only (Supabase Edge Functions) ──────────────────────────────
# NEVER put these in the client app. Used only inside Edge Functions.
# OPENAI_API_KEY=your-openai-api-key          ← server-side ONLY
# SUPABASE_SERVICE_ROLE_KEY=your-service-key  ← server-side ONLY

# ─── RevenueCat ──────────────────────────────────────────────────────────────
# Public SDK keys are safe to include in the client app.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your-revenuecat-ios-public-key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your-revenuecat-android-public-key
# Must match your RevenueCat entitlement identifier (default fallback is "premium").
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=premium
